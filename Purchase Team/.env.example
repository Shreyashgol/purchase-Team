GROQ_MODEL=llama-3.3-70b-versatile
PURCHASE_ORDER_API_URL=http://127.0.0.1:8002/purchase-orders/parse-and-execute
AP_INVOICE_API_URL=http://127.0.0.1:8003/ap-invoices/parse-and-execute
PURCHASE_RETURN_API_URL=http://127.0.0.1:8004/purchase-returns/parse-and-execute
